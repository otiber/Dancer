# ── DANCER LLM Configuration ──────────────────────────────────────────────────
# Copy this file to .env and fill in your own values. .env is git-ignored.

# Set to "true" to use a real LLM; "false" runs the deterministic mock.
USE_REAL_LLM=true

# ── Local LLM server (takes priority over all other providers) ────────────────
DANCER_BASE_URL=http://<host>:<port>/v1
DANCER_API_KEY=<token>
DANCER_MODEL=<served-model-name>

# ── OpenRouter (used if DANCER_BASE_URL is not set) ────────────────────────────
# OPENROUTER_API_KEY=<key>

# ── Direct OpenAI (used if neither of the above is set) ────────────────────────
# OPENAI_API_KEY=<key>
